{
	"name": "tailwind-nextjs-starter-blog",
	"version": "2.4.0",
	"private": true,
	"scripts": {
		"start": "next dev",
		"dev": "cross-env INIT_CWD=$PWD next dev",
		"build": "bun x contentlayer2 build && cross-env INIT_CWD=$PWD next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
		"build:cloudflare": "cross-env EXPORT=1 UNOPTIMIZED=1 bun run build",
		"serve": "next start",
		"sync-design": "node scripts/sync-design.mjs",
		"analyze": "cross-env ANALYZE=true next build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"prepare": "husky"
	},
	"dependencies": {
		"@algolia/client-search": "5.56.0",
		"@headlessui/react": "2.2.10",
		"@kjaniec-dev/design": "^0.9.0",
		"@kjaniec-dev/ui": "^0.9.0",
		"@next/bundle-analyzer": "16.2.11",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/postcss": "4.3.3",
		"@tailwindcss/typography": "0.5.20",
		"algoliasearch": "5.56.0",
		"contentlayer2": "0.5.8",
		"esbuild": "0.28.1",
		"github-slugger": "2.0.0",
		"gray-matter": "4.0.3",
		"hast-util-from-html-isomorphic": "2.0.0",
		"image-size": "2.0.2",
		"next": "16.2.11",
		"next-contentlayer2": "0.5.8",
		"next-themes": "0.4.6",
		"pliny": "0.4.1",
		"postcss": "8.5.22",
		"react": "19.2.8",
		"react-dom": "19.2.8",
		"reading-time": "1.5.0",
		"rehype-autolink-headings": "7.1.0",
		"rehype-citation": "2.3.2",
		"rehype-katex": "7.0.1",
		"rehype-katex-notranslate": "1.1.4",
		"rehype-preset-minify": "7.0.1",
		"rehype-prism-plus": "2.0.2",
		"rehype-slug": "6.0.0",
		"remark": "15.0.1",
		"remark-gfm": "4.0.1",
		"remark-github-blockquote-alert": "2.1.0",
		"remark-math": "6.0.0",
		"search-insights": "2.17.3",
		"tailwindcss": "4.3.3",
		"unist-util-visit": "5.1.0",
		"web-vitals": "6.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@testing-library/react": "^16.3.2",
		"@types/mdx": "2.0.14",
		"@types/react": "19.2.17",
		"@vitejs/plugin-react": "6.0.4",
		"@vitest/ui": "4.1.10",
		"cross-env": "10.1.0",
		"husky": "9.1.7",
		"jsdom": "29.1.1",
		"lint-staged": "17.2.0",
		"sharp": "0.35.3",
		"typescript": "6.0.3",
		"vitest": "4.1.10"
	},
	"overrides": {
		"next-themes": "0.4.6"
	},
	"lint-staged": {
		"*.+(js|jsx|ts|tsx|json|css)": [
			"biome check --write"
		]
	}
}
